# Horizon Member Portal - Environment Configuration
# Copy this file to .env and update values for your environment

# API Configuration
VITE_API_BASE_URL=https://api.example.com/v1

# Analytics / Tracking
VITE_GLASSBOX_ENABLED=false

# Session Configuration (in minutes)
VITE_SESSION_TIMEOUT_MINUTES=15
VITE_SESSION_WARNING_MINUTES=2

# Application
VITE_APP_NAME=Horizon Member Portal

# Support Contact Information
VITE_SUPPORT_EMAIL=support@horizonblue.com
VITE_SUPPORT_CHAT=https://www.horizonblue.com/chat
VITE_SUPPORT_PHONE=1-800-355-2583